      s7 s9 XCHG
      s6 s8 XCHG
      s5 s7 XCHG
      s4 s6 XCHG
      s3 s5 XCHG
      s4 s3 s0 XCHG3
      $Reputation$_fun_notify INLINECALLDICT
      $Reputation$_contract_store INLINECALLDICT
    }>
    15 BLKDROP
    15 BLKDROP
    15 BLKDROP
    7 BLKDROP
    130 THROW

      37 s() 39 s() XCHG
      36 s() 38 s() XCHG
      35 s() 37 s() XCHG
      34 s() 36 s() XCHG
      33 s() 35 s() XCHG
      32 s() 34 s() XCHG
      31 s() 33 s() XCHG
      30 s() 32 s() XCHG
      29 s() 31 s() XCHG
      28 s() 30 s() XCHG
      27 s() 29 s() XCHG
      26 s() 28 s() XCHG
      25 s() 27 s() XCHG
      24 s() 26 s() XCHG
      23 s() 25 s() XCHG
      22 s() 24 s() XCHG

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# TON Wallet (24-word mnemonic)
TON_MNEMONIC=word1 word2 word3 ... word24

# Or: base64-encoded secret key
# TON_PRIVATE_KEY=your-base64-key

# Network
TON_NETWORK=testnet
TON_RPC_URL=https://testnet-v4.tonhubapi.com

# OpenAI (for natural language parsing)
OPENAI_API_KEY=your-openai-api-key

# Optional: TonAPI key for enhanced queries
TONAPI_KEY=your-tonapi-key

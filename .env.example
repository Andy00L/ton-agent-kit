# ============================================================
# TON Agent Kit — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ── TON Wallet ──
# 24-word mnemonic phrase for your TON wallet
# Generate one with: bun run generate-wallet.ts
TON_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12 word13 word14 word15 word16 word17 word18 word19 word20 word21 word22 word23 word24

# Network: testnet or mainnet
TON_NETWORK=testnet

# RPC endpoint (optional — defaults based on network)
# TON_RPC_URL=https://testnet-v4.tonhubapi.com

# ── Telegram Bot (required for telegram-bot.ts) ──
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ── OpenAI (required for telegram-bot.ts) ──
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# ── TONAPI (optional — improves reliability) ──
# Get from https://tonapi.io
# TONAPI_KEY=your-tonapi-key

# ============================================================
# TON Agent Kit — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values you need.
# Variables marked "required" must be set for the core SDK to work.
# All others are optional and only needed for specific features.
# ============================================================


# ── Core (required) ─────────────────────────────────────────

# 24-word BIP39 mnemonic for your primary wallet
TON_MNEMONIC=word1 word2 word3 ... word24

# Network selection: "testnet" or "mainnet"
TON_NETWORK=testnet


# ── RPC Endpoint ────────────────────────────────────────────

# Custom TON RPC URL. Defaults to tonhubapi.com if not set.
# Used by: mcp-server.ts, telegram-bot.ts
# TON_RPC_URL=https://testnet-v4.tonhubapi.com


# ── AI Provider ─────────────────────────────────────────────

# OpenAI API key. Required for runLoop(), telegram-bot.ts, cloud-agent.ts.
OPENAI_API_KEY=sk-...

# Base URL for OpenAI-compatible providers (e.g. Azure, local LLM proxy).
# Defaults to https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# Model to use for LLM calls.
# telegram-bot.ts defaults to gpt-4.1-nano.
# cloud-agent.ts defaults to gpt-4o.
# AI_MODEL=gpt-4o


# ── Telegram Bot ────────────────────────────────────────────

# Telegram bot token from @BotFather. Required for telegram-bot.ts.
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token


# ── Cloud Agent ─────────────────────────────────────────────

# Display name for the cloud agent. Auto-generated if not set.
# AGENT_NAME=my-agent

# Comma-separated list of capability tags.
# AGENT_CAPABILITIES=general

# Seconds to wait between run loop iterations. Defaults to 30.
# COOLDOWN_SECONDS=30


# ── x402 Payment Server ─────────────────────────────────────

# Port for the built-in x402 HTTP server.
# Used by telegram-bot.ts (default 4000) and cloud-agent.ts (default 4000).
# X402_PORT=4000

# Public URL of the x402 server, used when advertising endpoints to other agents.
# Required in production deployments. Used by examples/x402-server.
# PUBLIC_URL=https://your-agent.example.com

# Set to "true" to run the x402 server in local mode (no public URL needed).
# Used by examples/x402-server.
# LOCAL_MODE=false


# ── 5-Agent Simulation (tests/26-autonomous-5agents.ts) ─────

# Additional wallets required for the 5-agent simulation.
# Each must be a 24-word mnemonic with testnet TON.
# TON_MNEMONIC_AGENT_B=word1 word2 ... word24   # Agent B (analytics-provider)
# TON_MNEMONIC_ARBITER1=word1 word2 ... word24  # Agent C (trader-bot)
# TON_MNEMONIC_ARBITER2=word1 word2 ... word24  # Agent D (deal-maker)
# TON_MNEMONIC_ARBITER3=word1 word2 ... word24  # Agent E (autonomous)

# Simulation duration in minutes. Defaults to 60.
# DURATION_MINUTES=60


# ── MCP Server ──────────────────────────────────────────────

# Transport mode: "stdio" (default) or "sse".
# MCP_TRANSPORT=stdio

# Port for SSE transport. Defaults to 3001.
# MCP_PORT=3001

# Bearer token for SSE auth. Auto-generated if not set.
# MCP_AUTH_TOKEN=

# CORS allowed origin for SSE transport. Defaults to *.
# MCP_CORS_ORIGIN=*


# ── Third-Party API Keys ─────────────────────────────────────

# TONAPI key for indexed blockchain data and higher rate limits.
# TONAPI_KEY=your_tonapi_key

# Swap.coffee API key for DeFi swap routing.
# SWAP_COFFEE_API_KEY=your_swap_coffee_key

# DYOR API key for token analytics.
# DYOR_API_KEY=your_dyor_key


# ── Reputation Contract (advanced) ──────────────────────────

# Address of a custom Reputation contract.
# Setting this creates a private ecosystem: your agents will only see
# agents registered on this contract.
# Omit to use the default shared contract.
# REPUTATION_CONTRACT=EQyour_contract_address_here

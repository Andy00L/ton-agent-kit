# ══════════════════════════════════════════════════════════════
# TON Agent Kit — Environment Variables
# ══════════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────────

# Your TON wallet mnemonic (24 words)
TON_MNEMONIC=word1 word2 word3 ... word24

# Network: "testnet" or "mainnet"
TON_NETWORK=testnet

# ── Optional: Additional Wallets (for testing) ───────────────

# Second agent wallet (buyer in commerce tests)
TON_MNEMONIC_AGENT_B=word1 word2 ... word24

# ── Additional Wallets (for multi-agent simulation) ──

TON_MNEMONIC_ARBITER1=    # Wallet C (trader-bot / arbiter)
TON_MNEMONIC_ARBITER2=    # Wallet D (deal-maker / arbiter)
TON_MNEMONIC_ARBITER3=    # Wallet E (autonomous agent)

# ── Simulation ──

DURATION_MINUTES=60        # test-autonomous.ts duration (default 60)

# ── Optional: Custom Ecosystem ────────────────────────────────

# Use your own reputation contract instead of the default shared one.
# Setting this creates a PRIVATE ecosystem — your agents won't see agents
# from the default ecosystem, and vice versa.
# REPUTATION_CONTRACT=EQyour_contract_address_here

# ── Optional: API Keys ────────────────────────────────────────

# OpenAI or compatible provider (for runLoop, orchestrator, telegram bot)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o

# TONAPI key (for indexed data — higher rate limits)
TONAPI_KEY=your_tonapi_key

# Telegram bot token (for telegram-bot.ts)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# DeFi API keys (for advanced DeFi primitives)
SWAP_COFFEE_API_KEY=your_swap_coffee_key
DYOR_API_KEY=your_dyor_key

# ── Optional: MCP Server SSE Transport ────────────────────────

# MCP_AUTH_TOKEN=         # Bearer token for SSE auth. Auto-generated if not set.
# MCP_TRANSPORT=stdio     # "stdio" (default) or "sse"
# MCP_PORT=3001           # SSE server port (default 3001)
# MCP_CORS_ORIGIN=*       # CORS allowed origin (default *)

# ── Optional: Custom RPC ──────────────────────────────────────

# Custom TON RPC endpoint (defaults to tonhubapi.com)
# TON_RPC_URL=https://testnet-v4.tonhubapi.com

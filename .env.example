# ============================================================
# TON Agent Kit -- Environment Variables
# ============================================================
# Copy to .env and fill in what you need.
# For the Telegram bot, see: https://github.com/Andy00L/ton-agent-bot
# ============================================================


# -- Wallet ---------------------------------------------------

# 24-word BIP39 mnemonic (required for on-chain operations)
# TON_MNEMONIC=word1 word2 word3 ... word24

# Or: raw ed25519 private key (hex). Alternative to mnemonic.
# Used by: packages/mcp-server, examples/mcp-server
# TON_PRIVATE_KEY=

# Network: "testnet" or "mainnet"
TON_NETWORK=testnet

# Custom TON RPC URL. Default: tonhubapi.com
# TON_RPC_URL=https://testnet-v4.tonhubapi.com


# -- AI / LLM -------------------------------------------------

# Required for runLoop() and autonomous agents.
# OPENAI_API_KEY=sk-...

# Override for OpenAI-compatible providers (Groq, Together, OpenRouter).
# OPENAI_BASE_URL=https://api.openai.com/v1

# Model ID. Default: gpt-4o
# AI_MODEL=gpt-4o


# -- MCP Server ------------------------------------------------

# Transport: "stdio" (default) or "sse"
# MCP_TRANSPORT=stdio

# Port for SSE transport. Default: 3001
# MCP_PORT=3001

# Bearer token for SSE auth. Auto-generated if not set.
# MCP_AUTH_TOKEN=

# CORS origin for SSE. Default: *
# MCP_CORS_ORIGIN=*


# -- Third-Party APIs ------------------------------------------

# TONAPI key for indexed data, webhooks, higher rate limits.
# TONAPI_KEY=

# swap.coffee API key for DCA, limit orders, yield pools.
# SWAP_COFFEE_API_KEY=

# DYOR.io API key for token trust scores.
# DYOR_API_KEY=


# -- x402 Examples (examples/x402-server) ----------------------

# Port for x402 payment server. Default: 3402
# X402_PORT=3402

# Public URL for advertising endpoints. Required in production.
# PUBLIC_URL=https://your-agent.example.com

# Set to "true" for localhost mode (no public URL needed).
# LOCAL_MODE=false


# -- Multi-Wallet (tests + simulations) ------------------------

# Additional wallets for multi-agent tests.
# TON_MNEMONIC_AGENT_B=word1 word2 ... word24
# TON_MNEMONIC_ARBITER1=word1 word2 ... word24
# TON_MNEMONIC_ARBITER2=word1 word2 ... word24
# TON_MNEMONIC_ARBITER3=word1 word2 ... word24

# Simulation duration in minutes. Default: 60
# DURATION_MINUTES=60

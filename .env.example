# ============================================================
# TON Agent Kit — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ── TON Wallet (required) ──
TON_MNEMONIC=word1 word2 ... word24
TON_NETWORK=testnet
# TON_RPC_URL=https://testnet-v4.tonhubapi.com

# ── Second Agent Wallet (required for demo-agent-commerce.ts) ──
# Generate a second testnet wallet and add its 24-word mnemonic
# TON_MNEMONIC_AGENT_B=word1 word2 ... word24

# ── Telegram Bot (required for telegram-bot.ts) ──
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ── AI Provider (required for telegram-bot.ts and demo-runloop.ts) ──
OPENAI_API_KEY=sk-your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o

# Provider examples (change OPENAI_BASE_URL and AI_MODEL):
# OpenRouter: OPENAI_BASE_URL=https://openrouter.ai/api/v1  AI_MODEL=anthropic/claude-sonnet-4-20250514
# Groq:       OPENAI_BASE_URL=https://api.groq.com/openai/v1  AI_MODEL=llama-3.3-70b-versatile
# Together:   OPENAI_BASE_URL=https://api.together.xyz/v1  AI_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
# Mistral:    OPENAI_BASE_URL=https://api.mistral.ai/v1  AI_MODEL=mistral-large-latest

# ── TONAPI (optional — improves reliability for analytics, NFT, DNS) ──
# TONAPI_KEY=your-tonapi-key
